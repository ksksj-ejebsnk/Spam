-- ⚙️ ฟังก์ชันหาผู้เล่นจากชื่อ
local function getPlayerByName(name)
	for _, p in pairs(game.Players:GetPlayers()) do
		if string.lower(p.Name) == string.lower(name) then
			return p
		end
	end
	return nil
end

-- ⚡ ฟังก์ชันวิ่งไว
speedButton.MouseButton1Click:Connect(function()
	local target = getPlayerByName(nameBox.Text)
	if target and target.Character and target.Character:FindFirstChild("Humanoid") then
		local hum = target.Character.Humanoid
		if hum.WalkSpeed < 50 then
			hum.WalkSpeed = 100
			speedButton.Text = "🏃 วิ่งปกติ"
			speedButton.BackgroundColor3 = Color3.fromRGB(255, 150, 0)
		else
			hum.WalkSpeed = 16
			speedButton.Text = "🏃 วิ่งไว"
			speedButton.BackgroundColor3 = Color3.fromRGB(0, 200, 100)
		end
	end
end)

-- 🕊️ ฟังก์ชันบิน
flyButton.MouseButton1Click:Connect(function()
	local target = getPlayerByName(nameBox.Text)
	if not target or not target.Character then return end

	local char = target.Character
	local hrp = char:WaitForChild("HumanoidRootPart")
	local hum = char:WaitForChild("Humanoid")

	local alreadyFlying = hrp:FindFirstChild("BodyGyro")
	if alreadyFlying then
		for _, v in pairs(hrp:GetChildren()) do
			if v:IsA("BodyGyro") or v:IsA("BodyVelocity") then v:Destroy() end
		end
		hum.PlatformStand = false
		flyButton.Text = "🕊️ บิน"
		flyButton.BackgroundColor3 = Color3.fromRGB(0, 150, 255)
	else
		hum.PlatformStand = true
		local bodyGyro = Instance.new("BodyGyro", hrp)
		bodyGyro.P = 9e4
		bodyGyro.MaxTorque = Vector3.new(9e9, 9e9, 9e9)
		local bodyVel = Instance.new("BodyVelocity", hrp)
		bodyVel.MaxForce = Vector3.new(9e9, 9e9, 9e9)

		flyButton.Text = "🕊️ หยุดบิน"
		flyButton.BackgroundColor3 = Color3.fromRGB(255, 200, 100)
	end
end)
