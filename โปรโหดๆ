local btnContainer = Instance.new("ScrollingFrame", main)
btnContainer.Size = UDim2.new(0, 380, 0, 330); btnContainer.Position = UDim2.new(0, 210, 0, 40)
btnContainer.BackgroundTransparency = 1; btnContainer.ScrollBarThickness = 3; btnContainer.AutomaticCanvasSize = Enum.AutomaticSize.Y
Instance.new("UIListLayout", btnContainer).Padding = UDim.new(0, 6)

local function createBtn(name, callback)
    local active = false
    local btn = Instance.new("TextButton", btnContainer)
    btn.Size = UDim2.new(1, -10, 0, 35); btn.Text = "ปิด | " .. name
    btn.BackgroundColor3 = Color3.fromRGB(25, 25, 35); btn.TextColor3 = Color3.new(1, 1, 1)
    btn.Font = Enum.Font.GothamBold; btn.TextSize = 11; Instance.new("UICorner", btn).CornerRadius = UDim.new(0, 6)
    btn.MouseButton1Click:Connect(function()
        active = not active; btn.Text = active and "เปิด | " .. name or "ปิด | " .. name
        btn.BackgroundColor3 = active and Color3.fromRGB(170, 0, 255) or Color3.fromRGB(25, 25, 35); callback(active)
    end)
end

